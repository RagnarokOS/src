MAKE = /usr/bin/make DESTDIR=${DESTDIR} -C

all:
	${MAKE} cat
	${MAKE} chgrp
	${MAKE} chmod
	${MAKE} chown
	${MAKE} cp
	${MAKE} date
	${MAKE} dd
	${MAKE} echo
	${MAKE} ed
	${MAKE} expr
	${MAKE} hostname
	${MAKE} kill
	${MAKE} ksh
	${MAKE} ln
	${MAKE} ls
	${MAKE} md5sum
	${MAKE} mkdir
	${MAKE} mv
	${MAKE} pwd
	${MAKE} rm
	${MAKE} rmdir
	${MAKE} sleep
	${MAKE} sync
	${MAKE} test

install:
	${MAKE} cat install
	${MAKE} chgrp install
	${MAKE} chmod install
	${MAKE} chown install
	${MAKE} cp install
	${MAKE} date install
	${MAKE} dd install
	${MAKE} echo install
	${MAKE} ed install
	${MAKE} expr install
	${MAKE} hostname install
	${MAKE} kill install
	${MAKE} ksh install
	${MAKE} ln install
	${MAKE} ls install
	${MAKE} md5sum install
	${MAKE} mkdir install
	${MAKE} mv install
	${MAKE} pwd install
	${MAKE} rm install
	${MAKE} rmdir install
	${MAKE} sleep install
	${MAKE} sync install
	${MAKE} test install

clean:
	${MAKE} cat clean
	${MAKE} chgrp clean
	${MAKE} chmod clean
	${MAKE} chown clean
	${MAKE} cp clean
	${MAKE} date clean
	${MAKE} dd clean
	${MAKE} echo clean
	${MAKE} expr clean
	${MAKE} hostname clean
	${MAKE} kill clean
	${MAKE} ksh clean
	${MAKE} ln clean
	${MAKE} ls clean
	${MAKE} md5sum clean
	${MAKE} mkdir clean
	${MAKE} mv clean
	${MAKE} pwd clean
	${MAKE} rm clean
	${MAKE} rmdir clean
	${MAKE} sleep clean
	${MAKE} sync clean
	${MAKE} test clean
