#!/bin/sh

# TEMPORARY: as long as the dev env is based on Debian,
# the GNU coreutils provided cat and its manual page needs
# to be removed.
if [ -f "/etc/debian_version" ]; then
	rm /bin/cat
	rm /usr/bin/cat
	rm /usr/share/man/man1/cat.1.gz
fi

# Building OpenBSD's cat(1)
make && make DESTDIR="$1" install

# Cleaning up
make clean
